{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "git", "cmd": "git", "args": true }
      ]
    }
  ]
}
